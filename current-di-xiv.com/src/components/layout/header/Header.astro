---
import HeaderButtonMenu from "@/components/layout/header/components/HeaderButtonMenu.astro";
interface Props {
  locale: string;
  headerContent: string;
}
const { locale, headerContent } = Astro.props as Props;

function getLocalizedRoute() {
  if (locale && locale !== "en") {
    return `/${locale}`;
  } else {
    return `/`;
  }
}
---

<header
  id="header"
  class="grid
  ultrawide-only:grid-cols-[1fr_55vw_1fr]
  grid-cols-[1fr_70vw_1fr]
  w-1150:grid-cols-[1fr_80vw_1fr]
  mobile-only:grid-cols-[1fr_90vw_1fr]"
>
  <div id="header-left"></div>
  <div id="header-center" class="relative">
    <div class="flex justify-center p-1">
      <a href={getLocalizedRoute()} class="flex justify-center items-center">
        <img
          src="/favicon.ico"
          class="w-10 mobile-only:w-8 h-auto"
          alt="Di-XIV Brand Icon"
        />
        <h1 class="regular text-base mobile-only:text-sm">{headerContent}</h1>
      </a>
    </div>
    <slot />
  </div>
  <div id="header-right"></div>
</header>

<HeaderButtonMenu />
