---
import Master from "@/layouts/Master.astro";
//
import ArtworksForArtists from "@/app/charrefs/ArtworksForArtists.astro";
//
import WCIF from "@/app/charrefs/WCIF.astro";
import SizesColorPallette from "@/app/charrefs/Sizes&ColorPallette.astro";
import DesignReferences from "@/app/charrefs/DesignReferences.astro";
//
import CopyStringToast from "@/app/charrefs/CopyStringToast.astro";
//
interface Props {
  // From Master
  locale: string;
  /// Meta
  metaDescription: string;
  metaKeywords: string;
  /// OpenGraph/Rich Links
  metaImageURL: string;
  metaImageFormat: string;
  metaImageHeight: string;
  metaImageWidth: string;
  metaImageAlt: string;
  /// Aside
  localizedAcknowledgements: string;
  localizedCharRefs: string;
  localizedCommWorks: string;
  localizedContact: string;
  localizedFAQ: string;
  localizedInquiries: string;
  localizedToU: string;
  headerContent: string;
  // Character References
  localizedDesignReferences: string;
  localizedAttireArtworks: string;
  localizedAttireShots: string;
  localizedBodyReferences: string;
  localizedHairstyles: string;
  localizedFullbodyFreckles: string;
  localizedGenitalia: string;
  localizedCharacterSheetArtworks: string;
  localizedSizesColorPallete: string;
  localizedWCIF: string;
  localizedCopiedCustomizeString: string;
  localizedCopiedGlamourerString: string;
  localizedDownloadAttires: string;
  localizedDownloadBodyRefs: string;
  localizedDownloadHairstyles: string;
  localizedLoading: string;
  localizedSpecialReferenceSummary: string;
  localizedDownloadThis: string;
  localizedDismiss: string;
  localizedClickToZoom: string;
  localizedDownload: string;
}

const {
  locale,
  localizedAcknowledgements,
  localizedToU,
  localizedInquiries,
  localizedFAQ,
  localizedContact,
  localizedCommWorks,
  localizedCharRefs,
  headerContent,
  metaImageURL,
  metaDescription,
  metaKeywords,
  metaImageFormat,
  metaImageHeight,
  metaImageWidth,
  metaImageAlt,
  localizedDesignReferences,
  localizedBodyReferences,
  localizedAttireShots,
  localizedHairstyles,
  localizedFullbodyFreckles,
  localizedGenitalia,
  localizedAttireArtworks,
  localizedCharacterSheetArtworks,
  localizedSizesColorPallete,
  localizedWCIF,
  localizedCopiedCustomizeString,
  localizedCopiedGlamourerString,
  localizedDownloadAttires,
  localizedDownloadBodyRefs,
  localizedDownloadHairstyles,
  localizedLoading,
  localizedSpecialReferenceSummary,
  localizedDownloadThis,
  localizedClickToZoom,
  localizedDismiss,
  localizedDownload,
} = Astro.props as Props;
---

<Master
  locale={locale}
  localizedAcknowledgements={localizedAcknowledgements}
  localizedCharRefs={localizedCharRefs}
  localizedCommWorks={localizedCommWorks}
  localizedContact={localizedContact}
  localizedFAQ={localizedFAQ}
  localizedInquiries={localizedInquiries}
  localizedToU={localizedToU}
  headerContent={headerContent}
  metaDescription={metaDescription}
  metaKeywords={metaKeywords}
  metaImageURL={metaImageURL}
  metaImageFormat={metaImageFormat}
  metaImageWidth={metaImageWidth}
  metaImageHeight={metaImageHeight}
  metaImageAlt={metaImageAlt}
>
  <div
    id="toasts-container"
    class="fixed top-[5%] right-[5%] z-20 grid grid-cols-1 gap-2"
  >
    <CopyStringToast
      localizedToast={localizedCopiedCustomizeString}
      toastID="customize-toast"
      stringToCopy=""
      triggerButtonID="customize-string"
    >
      <div>
        <img
          src="/icons/content/wcif/customize-svgrepo-com.svg"
          class="h-11 mobile-only:h-6 w-auto mr-1"
        />
      </div>
    </CopyStringToast>
    <CopyStringToast
      localizedToast={localizedCopiedGlamourerString}
      toastID="glamourer-toast"
      stringToCopy=""
      triggerButtonID="glamourer-string"
    >
      <img
        src="/icons/content/wcif/elegante-makeup-svgrepo-com.svg"
        class="h-11 mobile-only:h-6 w-auto mr-1"
      />
    </CopyStringToast>
  </div>
  <div class="grid grid-cols-1 gap-4 mobile-only:mt-[5%] px-2">
    <ArtworksForArtists
      localizedLoading={localizedLoading}
      localizedSpecialReferenceSummary={localizedSpecialReferenceSummary}
    />
    <DesignReferences
      localizedDesignReferences={localizedDesignReferences}
      localizedAttireShots={localizedAttireShots}
      localizedBodyReferences={localizedBodyReferences}
      localizedFullbodyFreckles={localizedFullbodyFreckles}
      localizedHairstyles={localizedHairstyles}
      localizedGenitalia={localizedGenitalia}
      localizedDownloadAttires={localizedDownloadAttires}
      localizedDownloadBodyRefs={localizedDownloadBodyRefs}
      localizedDownloadHairstyles={localizedDownloadHairstyles}
      localizedDownloadThis={localizedDownloadThis}
      localizedClickToZoom={localizedClickToZoom}
      localizedDismiss={localizedDismiss}
    />
    <SizesColorPallette
      locale={locale}
      localizedSizesColorPallete={localizedSizesColorPallete}
      localizedAttireArtworks={localizedAttireArtworks}
      localizedCharacterSheetArtworks={localizedCharacterSheetArtworks}
      localizedClickToZoom={localizedClickToZoom}
      localizedDismiss={localizedDismiss}
      localizedDownload={localizedDownload}
    />
    <WCIF
      locale={locale}
      trueLocale={locale}
      localizedWCIF={localizedWCIF}
      localizedCopiedCustomizeString={localizedCopiedCustomizeString}
      localizedCopiedGlamourerString={localizedCopiedGlamourerString}
    />
  </div>
</Master>
