---
import CopyButton from "@/components/contact-card/contact-buttons/CopyButton.astro";
import LinkButton from "@/components/contact-card/contact-buttons/LinkButton.astro";
interface Props {
  localizedClickToCopy: string;
  localizedLinkTo: string;
}

const { localizedClickToCopy, localizedLinkTo } = Astro.props as Props;
---

<div id="buttons-container" class="flex justify-center mt-[2%]">
  <div class="grid grid-cols-3 mobile-only:grid-cols-2 gap-2">
    <CopyButton
      copyButtonContent="hello@theblack.cat"
      copyButtonID="email-button"
      copyButtonText="Email"
      copyButtonToastID="email-toast"
      localizedTitleCopy={localizedClickToCopy}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        slot="inline-svg"
        class="mobile-only:h-6 h-12 mr-1"
        viewBox="0 0 48 48"
        ><path
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M9.5 13c13.687 13.574 14.825 13.09 29 0"></path><rect
          width="37"
          height="31"
          x="5.5"
          y="8.5"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          rx="4"
          ry="4"></rect></svg
      >
    </CopyButton>
    <LinkButton
      linkButtonHref="https://x.com/di_theblackcat"
      linkButtonID="twitter-button"
      linkButtonText="Twitter"
      localizedTitleLink={localizedLinkTo}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        slot="inline-svg"
        class="mobile-only:h-6 h-12 mr-1"
        viewBox="0 0 48 48"
        ><path
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M38.74 16.55v1c0 10.07-7.64 21.61-21.62 21.61A21.14 21.14 0 0 1 5.5 35.71a12 12 0 0 0 1.81.11a15.25 15.25 0 0 0 9.44-3.24a7.56 7.56 0 0 1-7.1-5.29a7 7 0 0 0 1.44.15a7.5 7.5 0 0 0 2-.27A7.57 7.57 0 0 1 7 19.72v-.1a7.4 7.4 0 0 0 3.44.94A7.54 7.54 0 0 1 8.05 10.5a21.58 21.58 0 0 0 15.68 7.94a6.4 6.4 0 0 1-.21-1.74a7.55 7.55 0 0 1 13.17-5.31a15.6 15.6 0 0 0 4.83-1.85a7.65 7.65 0 0 1-3.39 4.27a15.9 15.9 0 0 0 4.37-1.26a15.6 15.6 0 0 1-3.76 4"
        ></path></svg
      >
    </LinkButton>
    <CopyButton
      copyButtonContent="di_theblackcat"
      copyButtonID="discord-button"
      copyButtonText="Discord"
      copyButtonToastID="discord-toast"
      localizedTitleCopy={localizedClickToCopy}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        slot="inline-svg"
        class="mobile-only:h-6 h-12 mr-1"
        viewBox="0 0 48 48"
        ><path
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M17.54 34.22A47 47 0 0 1 14.68 38C7.3 37.79 4.5 33 4.5 33a44.8 44.8 0 0 1 4.81-19.52A16.47 16.47 0 0 1 18.69 10l1 2.31"
        ></path><path
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M17.85 22.67a3.48 3.48 0 0 0-3.37 3.9a3.38 3.38 0 0 0 3.31 3.22a3.53 3.53 0 0 0 3.43-3.9a3.45 3.45 0 0 0-3.37-3.22m-5.65-8.3a28.2 28.2 0 0 1 8.16-2.18A23 23 0 0 1 24 12a23 23 0 0 1 3.64.21a28.2 28.2 0 0 1 8.16 2.18m-7.47-2.09l1-2.31a16.47 16.47 0 0 1 9.38 3.51A44.8 44.8 0 0 1 43.5 33s-2.8 4.79-10.18 5a47 47 0 0 1-2.86-3.81m6.46-2.9a29.6 29.6 0 0 1-8.64 3.49a21.3 21.3 0 0 1-4.28.4h0a21.3 21.3 0 0 1-4.28-.4a29.6 29.6 0 0 1-8.64-3.49"
        ></path><path
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M30.15 22.67a3.48 3.48 0 0 1 3.37 3.9a3.38 3.38 0 0 1-3.31 3.22a3.53 3.53 0 0 1-3.43-3.9a3.45 3.45 0 0 1 3.37-3.22"
        ></path></svg
      >
    </CopyButton>
    <LinkButton
      linkButtonHref="https://tellonym.me/ditheblackcat"
      linkButtonID="tellonym-button"
      linkButtonText="Tellonym"
      localizedTitleLink={localizedLinkTo}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        slot="inline-svg"
        class="mobile-only:h-6 h-12 mr-1"
        viewBox="0 0 48 48"
        ><path
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M24.988 30.37c3.591 1.84 6.515 1.831 9.173-.984m4.156-5.036a1.967 1.967 0 1 1-3.934 0a1.967 1.967 0 0 1 3.934 0m-14.211 1.053c0 1.086-.88 1.967-1.967 1.967h0a1.967 1.967 0 1 1 1.967-1.967M15.556 5.5l25.536.905c.637-.19.652 9.493.591 14.317c-.083 6.592.028 19.777.028 19.777l-2.573-2.039c-.859-.68-1.303-.83-2.105.009l-3.09 3.232l-3.416-2.437c-.696-.496-1.157-1.062-2.337 0l-3.117 2.804l-3.855-2.492c-.512-.33-1.152-1.103-2.246.148L16.546 42.5c-.884-17.175-.58-25.606-.99-37M6.334 9.707s-.076 3.272-.029 4.907c.256 8.92 1.693 26.716 1.693 26.716l2.534-1.1c.531-.23.59-.121 1.047.08M15.556 5.5L6.334 9.707l3.664 6.19M15.556 5.5L9.998 15.898l1.58 24.412l4.968 2.19"
        ></path></svg
      >
    </LinkButton>
    <LinkButton
      linkButtonHref="https://www.pixiv.net/en/users/98072277"
      linkButtonID="pixiv-button"
      linkButtonText="pixiv"
      localizedTitleLink={localizedLinkTo}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        slot="inline-svg"
        class="mobile-only:h-6 h-12 mr-1"
        viewBox="0 0 48 48"
        ><path
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M13.281 9.296V42.5m-2.183 0h4.366M4.388 16.214C7.878 12.73 15.819 5.5 27.198 5.5s16.414 8.83 16.414 15.467s-6.34 14.578-16.77 14.578s-13.561-3.911-13.561-3.911m-8.893-15.42l1.061 2.205"
        ></path></svg
      >
    </LinkButton>
    <LinkButton
      linkButtonHref="https://aethy.com/@di_theblackcat"
      linkButtonID="aethy-button"
      linkButtonText="Aethy"
      localizedTitleLink={localizedLinkTo}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        slot="inline-svg"
        class="mobile-only:h-6 h-12 mr-1"
        viewBox="0 0 48 48"
        ><path
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M41.066 20.402c0 6.257-.972 8.397-2.884 10.19C34.308 34.226 24 33.942 24 33.942a40.3 40.3 0 0 1-7.014-.528s-1.126 7.414 13.104 3.778l-.144 4.24c-2.169.29-22.807 7.92-22.957-18.656L6.934 20.4c0-6.258.05-8.482 2.884-11.611C13.383 4.853 24 5.355 24 5.355s10.617-.502 14.182 3.435c2.834 3.129 2.884 5.354 2.884 11.611"
        ></path><path
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M24 23.313v-5.978a4.654 4.654 0 0 0-4.654-4.654h0a4.654 4.654 0 0 0-4.654 4.654v9.646M24 17.335a4.654 4.654 0 0 1 4.654-4.654h0a4.654 4.654 0 0 1 4.655 4.654v9.646"
        ></path></svg
      >
    </LinkButton>
  </div>
</div>
