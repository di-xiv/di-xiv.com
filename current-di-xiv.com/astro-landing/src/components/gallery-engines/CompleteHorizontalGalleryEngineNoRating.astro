---
interface Props {
  apiURL: string;
}

const { apiURL } = Astro.props;

let basicGalleryEngine = [];
let loading = true;
let error = null;

try {
  const response = await fetch(apiURL);
  if (!response.ok) {
    throw new Error(`HTTP error! status: ${response.status}`);
  }
  basicGalleryEngine = await response.json();
} catch (err) {
  console.error("Failed to fetch gallery data:", err);
  error = err.message;
} finally {
  loading = false;
}
---

{
  loading ? (
    <p class="flex justify-center">Loading...</p>
  ) : error ? (
    <p class="flex justify-center">Error loading data: {error}</p>
  ) : basicGalleryEngine.length > 0 ? (
    basicGalleryEngine.map((gallery) => (
      <article key={gallery.gallery_id}>
        <div class="flex justify-evenly items-center glassbox mobile-only:p-2 p-4 rounded-md select-none mt-[5%] mb-[5%]">
          <div class="flex items-center">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-9 mobile-only:h-4 w-auto inline-block svg-invert mr-1"
              viewBox="0 0 16 16"
            >
              <path
                fill="black"
                d="M1.75 3a.75.75 0 0 0 0 1.5h12.5a.75.75 0 0 0 0-1.5zm0 3a.75.75 0 0 0 0 1.5h12.5a.75.75 0 0 0 0-1.5zM1 9.75A.75.75 0 0 1 1.75 9h12.5a.75.75 0 0 1 0 1.5H1.75A.75.75 0 0 1 1 9.75M1.75 12a.75.75 0 0 0 0 1.5h8.5a.75.75 0 0 0 0-1.5z"
              />
            </svg>
            <h2 class="regular text-2xl inline-block w905:text-xl mobile-only:text-sm">
              {gallery.gallery_name}
            </h2>
          </div>
          {gallery.artworks[0]?.artist && (
            <div class="flex items-center select-none">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 mobile-only:h-4 w-auto svg-invert mr-1"
                viewBox="0 0 16 16"
              >
                <path
                  fill="black"
                  d="M11.134 1.535c.7-.509 1.416-.942 2.076-1.155c.649-.21 1.463-.267 2.069.34c.603.601.568 1.411.368 2.07c-.202.668-.624 1.39-1.125 2.096c-1.011 1.424-2.496 2.987-3.775 4.249c-1.098 1.084-2.132 1.839-3.04 2.3a3.74 3.74 0 0 1-1.055 3.217c-.431.431-1.065.691-1.657.861c-.614.177-1.294.287-1.914.357A21 21 0 0 1 .797 16H.743l.007-.75H.749L.742 16a.75.75 0 0 1-.743-.742l.743-.008l-.742.007v-.054a21 21 0 0 1 .13-2.284q.101-.972.358-1.914c.17-.591.43-1.226.86-1.657a3.75 3.75 0 0 1 3.227-1.054c.466-.893 1.225-1.907 2.314-2.982c1.271-1.255 2.833-2.75 4.245-3.777M1.62 13.089q-.077.696-.104 1.395q.7-.027 1.396-.104a10.5 10.5 0 0 0 1.668-.309c.526-.151.856-.325 1.011-.48a2.25 2.25 0 1 0-3.182-3.182c-.155.155-.329.485-.48 1.01a10.5 10.5 0 0 0-.309 1.67m10.396-10.34c-1.224.89-2.605 2.189-3.822 3.384l1.718 1.718c1.21-1.205 2.51-2.597 3.387-3.833c.47-.662.78-1.227.912-1.662c.134-.444.032-.551.009-.575h-.001V1.78c-.014-.014-.113-.113-.548.027c-.432.14-.995.462-1.655.942m-4.832 7.266a10 10 0 0 0 1.63-1.142L7.155 7.216a9.7 9.7 0 0 0-1.161 1.607c.482.302.889.71 1.19 1.192"
                />
              </svg>
              <a
                href={gallery.artworks[0].artist.website}
                rel="noopener noreferer"
                target="_blank"
                class="inline-block text-2xl hover:underline regular w905:text-xl mobile-only:text-sm"
                title={`Go to ${gallery.artworks[0].artist.artist_name} webpage!`}
              >
                {gallery.artworks[0].artist.artist_name}↗
              </a>
            </div>
          )}
        </div>
        <ul
          id={`${gallery.gallery_name}-${gallery.gallery_id}-gallery-wrapper`}
          class="flex overflow-x-auto gap-4 glassbox rounded-md text-sm"
        >
          {gallery.artworks.map((artwork) => {
            const isVideo = /\.(mp4|mkv)$/i.test(artwork.artwork_url);
            return (
              <li key={artwork.artwork_id} class="flex-shrink-0 box-border">
                <div
                  id={`${artwork.artist.artist_name}-${gallery.gallery_name}-gallery-wrapper`}
                  class="p-4 mobile-only:p-2"
                >
                  {isVideo ? (
                    <video class="h-[85vh] w-auto rounded-sm" controls>
                      <source src={artwork.artwork_url} type="video/mp4" />
                      Your browser does not support the video tag.
                    </video>
                  ) : (
                    <img
                      src={artwork.artwork_url}
                      class="h-[85vh] w-auto rounded-sm"
                      alt={`${artwork.artist.artist_name}: ${gallery.gallery_name}`}
                    />
                  )}
                </div>
                {artwork.tags.length > 0 && (
                  <div
                    id={`${artwork.artist.artist_name}-${gallery.gallery_name}-tags-wrapper`}
                    class="flex items-center justify-center gap-2 mt-4 mobile-only:hidden md:flex mb-[2%]"
                  >
                    {artwork.tags.map((tag) => {
                      let borderColorClass = "";
                      switch (tag.rating_id) {
                        case 1:
                          borderColorClass =
                            "border-green-500 bg-green-500 text-white";
                          break;
                        case 2:
                          borderColorClass =
                            "border-red-500 bg-red-500 text-white";
                          break;
                        case 3:
                          borderColorClass =
                            "border-purple-500 bg-purple-500 text-white";
                          break;
                        default:
                          borderColorClass = "border-black";
                      }
                      return (
                        <div key={tag.tag_id}>
                          <div
                            id={`${artwork.artist.artist_name}-${gallery.gallery_name}-individual-tag-wrapper`}
                            class={`flex items-center border border-solid p-1 rounded-md select-none ${borderColorClass}`}
                          >
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              class="h-4 w-auto inline-block mr-1"
                              style="filter: invert(100%);color:white"
                              viewBox="0 0 32 32"
                            >
                              <path
                                fill="black"
                                d="M15.952 4.079A4 4 0 0 1 18.684 3H25.5A3.5 3.5 0 0 1 29 6.5v6.757a4 4 0 0 1-1.172 2.829L16.005 27.909a4.25 4.25 0 0 1-6.01 0l-6.326-6.326a4.25 4.25 0 0 1 .101-6.109zM22.5 12a2.5 2.5 0 1 0 0-5a2.5 2.5 0 0 0 0 5"
                              />
                            </svg>
                            <span
                              class="text-xl regular"
                              title={`Tag: ${tag.tag_name}`}
                            >
                              {tag.tag_name}
                            </span>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                )}
              </li>
            );
          })}
        </ul>
      </article>
    ))
  ) : (
    <p class="flex justify-center">No data available.</p>
  )
}
