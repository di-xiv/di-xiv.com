---
import CopyToastNotification from "@/components/reusables/CopyToastNotification.astro";
interface Props {
  lang: string;
  localizedWCIF: string;
  localizedCopiedCustomizeString: string;
  localizedCopiedGlamourerString: string;
}

const {
  lang,
  localizedWCIF,
  localizedCopiedCustomizeString,
  localizedCopiedGlamourerString,
} = Astro.props as Props;
let LocalizedWCIF;
try {
  LocalizedWCIF = await import(`./${lang}/WCIF.mdx`);
} catch (e) {
  console.error("Error loading localized component:", e);
}
---

<CopyToastNotification
  localizedToast={localizedCopiedCustomizeString}
  toastID="customize-toast"
  iconURL="/icons/nav/line-md--confirm-circle.svg"
/>
<CopyToastNotification
  localizedToast={localizedCopiedGlamourerString}
  toastID="glamourer-toast"
  iconURL="/icons/nav/line-md--confirm-circle.svg"
/>
<details id="ffxiv-wcif" class="glassbox p-3 mobile-only:p-2 rounded-lg">
  <summary class="regular text-2xl mb-[1%] mt-[1%]">
    {localizedWCIF}
  </summary>
  <div class="flex justify-center">
    <div
      class="mdx-container w-[80%] glassbox p-2 rounded-md
          mobile-only:w-[90%] mobile-only:ml-0 mb-[2%] mt-[1%] not-mobile:pl-[3%] pb-[3%]"
    >
      {
        LocalizedWCIF ? (
          <LocalizedWCIF.default />
        ) : (
          <div>Error loading component</div>
        )
      }
    </div>
  </div>
</details>
<script>
  document
    .getElementById("customize-string")
    .addEventListener("click", function () {
      const customizeString =
        "";
      navigator.clipboard
        .writeText(customizeString)
        .then(function () {
          const toast = document.getElementById("customize-toast");
          toast.style.display = "block";
          setTimeout(function () {
            toast.style.display = "none";
          }, 3000);
        })
        .catch(function (err) {
          console.error("Could not copy text: ", err);
        });
    });
  document
    .getElementById("glamourer-string")
    .addEventListener("click", function () {
      const glamourerString =
        "";
      navigator.clipboard
        .writeText(glamourerString)
        .then(function () {
          const toast = document.getElementById("glamourer-toast");
          toast.style.display = "block";
          setTimeout(function () {
            toast.style.display = "none";
          }, 3000);
        })
        .catch(function (err) {
          console.error("Could not copy text: ", err);
        });
    });
</script>
